{
  "name": "onenote-mcp",
  "displayName": "OneNote MCP Server",
  "description": "Model Context Protocol server for Microsoft OneNote - enables AI agents to read, search, and write OneNote pages",
  "version": "1.0.0",
  "publisher": "rashmirrout",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rashmirrout/OneNoteMCP"
  },
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "onenote",
    "microsoft",
    "copilot",
    "claude",
    "ai"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "mcpServerDefinitionProviders": [
      {
        "id": "onenoteMcp",
        "label": "OneNote MCP Server"
      }
    ],
    "commands": [
      {
        "command": "onenote-mcp.login",
        "title": "OneNote MCP: Sign In"
      },
      {
        "command": "onenote-mcp.logout",
        "title": "OneNote MCP: Sign Out"
      },
      {
        "command": "onenote-mcp.status",
        "title": "OneNote MCP: Check Auth Status"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "dependencies": {
    "@azure/msal-node": "^3.8.4",
    "@azure/msal-node-extensions": "^1.5.26",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "marked": "^15.0.0",
    "open": "^10.1.0",
    "pako": "^2.1.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pako": "^2.0.3",
    "@types/vscode": "^1.96.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vscode/vsce": "^3.2.0",
    "eslint": "^9.0.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.7.0",
    "webpack": "^5.97.0",
    "webpack-cli": "^6.0.0"
  }
}
